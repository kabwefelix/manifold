# Manifold Cognitive Architecture - Environment Blueprint
# Copy this file to .env and fill in your actual values.

# The primary brain
DEEPSEEK_API_KEY="your_api_key_here"

# For the ArchitectNode's autonomous evolution loops
GITHUB_TOKEN="your_github_token_here"
GITHUB_REPOSITORY="owner/repo"

# The absolute path where all logs, DBs, and artifacts will live
MANIFOLD_HOME="/absolute/path/to/manifold/data"

# Boolean gate for Manifold enablement (True/False)
MANIFOLD_ENABLED="True"
